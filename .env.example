# oh-my-openclaw environment variables
# Copy to .env and fill in your values

# Telegram Bot (for test-drive workflow)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Anthropic Compatible API (e.g., SiliconFlow, DashScope)
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.siliconflow.cn/v1
ANTHROPIC_MODEL=Pro/MiniMaxAI/MiniMax-M2.5

# OpenAI Compatible API (optional, takes priority if set)
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=

# OpenCLAW Gateway
OPENCLAW_GATEWAY_PORT=18789